{
  "expo": {
    "name": "Boni Buddy",
    "slug": "boni-buddy",
    "scheme": "bonibuddy",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#00A6F6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "si.bonibuddy.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "si.bonibuddy.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00A6F6",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5271754f-8907-4a55-b3c3-f69461e6b75d"
      }
    },
    "owner": "acuveth"
  }
}
