{
  "expo": {
    "name": "Boni Buddy",
    "slug": "boni-buddy",
    "scheme": "bonibuddy",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#00A6F6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "si.bonibuddy.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Boni Buddy potrebuje dostop do fotografij, da lahko dodaš profilne slike.",
        "NSCalendarsUsageDescription": "Boni Buddy potrebuje dostop do koledarja, da lahko shraniš dogovorjen bon kot dogodek.",
        "NSCalendarsFullAccessUsageDescription": "Boni Buddy potrebuje dostop do koledarja, da lahko shraniš dogovorjen bon kot dogodek.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "si.bonibuddy.app",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./android/app/google-services.json",
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00A6F6",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "95ecf26f-ff86-49f2-ba98-b0ba2939219e"
      }
    },
    "owner": "jakoa3"
  }
}
